# =============================================================================
# Aura Living — Environment Variables (TEMPLATE)
# Copy this file to `.env` and fill in real values.
# Never commit your real `.env` file.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase (Postgres + Storage) — REQUIRED
# -----------------------------------------------------------------------------
# Get these from: Supabase Dashboard → your project → Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Connection pooler (PgBouncer, transaction mode, IPv4) — used by Prisma Client.
# Get from: Supabase Dashboard → Settings → Database → Connection string → Transaction pooler
# If your password contains special chars (!, #, @, etc.), URL-encode them.
# Example: "Pa!ss#word" → "Pa%21ss%23word"
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR_URL_ENCODED_PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct connection (session mode pooler) — used by Prisma Migrate.
DIRECT_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR_URL_ENCODED_PASSWORD@aws-1-REGION.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# Better Auth — REQUIRED
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING

# -----------------------------------------------------------------------------
# Storage buckets (create these in Supabase dashboard → Storage)
# -----------------------------------------------------------------------------
SUPABASE_BUCKET_PRODUCTS=product-images
SUPABASE_BUCKET_AVATARS=user-avatars
SUPABASE_BUCKET_REVIEWS=review-images
SUPABASE_BUCKET_ADMIN=admin-assets

# -----------------------------------------------------------------------------
# OPTIONAL — In-house features (all have safe defaults; no external keys needed)
# -----------------------------------------------------------------------------
# Email queue uses console logger in dev. To enable SMTP later:
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM="Aura Living <hello@yourdomain.pk>"
